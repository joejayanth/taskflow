{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's public profile.",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile picture."
        }
      },
      "required": ["displayName", "email", "photoURL"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "Represents a task within the TaskFlow application.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the task, supports rich text formatting."
        },
        "priority": {
          "type": "string",
          "description": "Priority level of the task (P0, P1, P2, P3).",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "dueDate": {
          "type": "string",
          "description": "Due date for the task.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status of the task (Yet to Start, WIP, In Review, Done).",
          "enum": ["Yet to Start", "WIP", "In Review", "Done"]
        },
        "history": {
            "type": "array",
            "items": {
                "$ref": "#/entities/StatusUpdate"
            }
        }
      },
      "required": [
        "title",
        "description",
        "priority",
        "dueDate",
        "status",
        "history"
      ]
    },
    "StatusUpdate": {
      "title": "Status Update",
      "type": "object",
      "description": "Represents a single status change event for a task.",
      "properties": {
        "status": {
          "type": "string",
          "description": "The status that the task was changed to."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp when the status was changed.",
          "format": "date-time"
        }
      },
      "required": ["status", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
        "schema": {
            "$ref": "#/entities/UserProfile"
        },
        "description": "Stores public profile information for a user."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/Task"
      },
      "description": "Stores task information for a specific user. Path-based ownership is enforced through the `userId` parameter."
    }
  }
}
